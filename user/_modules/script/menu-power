#!/usr/bin/env bash
set -euo pipefail

list="пЂЈ Lock\nп“® Suspend\nојЊ Log Out\nпЂЎ Reboot\nпЂ‘ Shutdown"

case $(echo -e "$list" | rofi -dmenu -p "> ") in
*"Lock")
    swaylock -f
    ;;
*"Suspend")
    systemctl suspend
    ;;
*"Log Out")
    niri msg action quit
    ;;
*"Reboot")
    systemctl reboot
    ;;
*"Shutdown")
    systemctl poweroff
    ;;
esac
